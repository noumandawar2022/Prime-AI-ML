def get_recommendation(b):
    recommendation = []
    for i in b:
        curr_recom = {}
        curr_recom["name"] = i["name"]
        if(float(i["rating"] ) >= 4):
            curr_recom["brand"] = "Apple"
        else:
            curr_recom["brand"] = "Samsung"
        
        recommendation.append(curr_recom)
    return recommendation


get_recommendation(b)

