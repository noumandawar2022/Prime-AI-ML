import matplotlib.pyplot as plt
import numpy as np


np.random.seed(0)
scores = np.random.normal(70,10,100)
bins1  = [0,30,70,90,100]
plt.hist(scores, edgecolor = "black", color = "skyblue", bins = bins1)
plt.xlabel("marks")
plt.axvline(
    x=33,
    label= "Passing Marks (33)",
    color = "red",
    linewidth= "2",
    linestyle = "--"
)
plt.legend()
plt.ylabel("no. of students")
plt.title("histogram of students marks")


plt.show()











